# 🌐 مفاتيح عامة (تظهر في المتصفح - آمنة مع وجود RLS)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# 🔐 مفاتيح سرية (لا تظهر في المتصفح - لا تضع بادئة VITE_)
# ⚠️ لا ترفع هذا الملف أبداً للإنتاج، استخدم لوحة تحكم Vercel/Hosting
SUPABASE_SERVICE_ROLE_KEY=your-super-secret-service-role-key

# 🤖 مفاتيح الذكاء الاصطناعي
VITE_GEMINI_API_KEY=your-gemini-key